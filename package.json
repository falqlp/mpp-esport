{
  "name": "mpp-esport",
  "private": true,
  "version": "0.1.0",
  "description": "V1 d'une application de pronostics esport orientee League of Legends.",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "yarn dev:api",
    "dev:api": "yarn workspace @mpp-esport/api start:dev",
    "dev:web": "yarn workspace @mpp-esport/web start",
    "build": "yarn build:api && yarn build:web",
    "build:api": "yarn workspace @mpp-esport/api build",
    "build:web": "yarn workspace @mpp-esport/web build",
    "test:api": "yarn workspace @mpp-esport/api test",
    "test:api:coverage": "yarn workspace @mpp-esport/api test:coverage",
    "lint": "node node_modules/eslint/bin/eslint.js \"apps/**/*.{ts,html}\"",
    "lint:fix": "yarn lint --fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write .",
    "format:check": "node node_modules/prettier/bin/prettier.cjs --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1"
  }
}
