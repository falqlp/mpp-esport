generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  favoriteCompetitions String[] @default([])
  createdAt    DateTime @default(now())
  predictions  Prediction[]

  @@map("users")
}

model Prediction {
  id         String   @id @default(cuid())
  matchId    String
  userId     String
  winnerId   String
  scoreA     Int
  scoreB     Int
  createdAt  DateTime @default(now())
  points     Int      @default(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId])
  @@map("predictions")
}

model Match {
  id         String   @id
  league     String
  leagueLogoUrl String?
  tournament String
  startsAt   DateTime
  format     String
  status     String
  teams      Json
  winnerId   String?
  scoreA     Int?
  scoreB     Int?
  syncedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt
  predictions Prediction[]

  @@index([status, startsAt])
  @@map("matches")
}

model SyncRequest {
  id          String   @id
  requestedAt DateTime

  @@map("sync_requests")
}
