generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  favoriteCompetitions String[] @default(["EWC"])
  avatarUrl     String?  @db.Text
  bio           String?  @db.VarChar(300)
  createdAt    DateTime @default(now())
  predictions  Prediction[]
  ownedGroups  Group[] @relation("GroupOwner")
  groupMemberships GroupMembership[]

  @@map("users")
}

model Prediction {
  id         String   @id @default(cuid())
  matchId    String
  userId     String
  winnerId   String
  scoreA     Int
  scoreB     Int
  createdAt  DateTime @default(now())
  points     Int      @default(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId])
  @@map("predictions")
}

model Match {
  id         String   @id
  league     String
  leagueLogoUrl String?
  tournament String
  tournamentId String
  startsAt   DateTime
  format     String
  status     String
  teams      Json
  winnerId   String?
  scoreA     Int?
  scoreB     Int?
  syncedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt
  predictions Prediction[]
  tournamentRelation Tournament @relation(fields: [tournamentId], references: [id], onDelete: Restrict)
  teamLinks MatchTeam[]

  @@index([status, startsAt])
  @@map("matches")
}

model Team {
  id         String   @id
  name       String
  acronym    String?
  imageUrl   String?  @db.Text
  updatedAt  DateTime @updatedAt
  rosters    Roster[]
  matches    MatchTeam[]

  @@map("teams")
}

model MatchTeam {
  matchId String
  teamId  String
  position Int
  match   Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team    Team  @relation(fields: [teamId], references: [id], onDelete: Restrict)

  @@id([matchId, teamId])
  @@unique([matchId, position])
  @@index([teamId])
  @@map("match_teams")
}

model Tournament {
  id        String   @id
  name      String
  matches   Match[]
  rosters   Roster[]

  @@map("tournaments")
}

model Player {
  id          String   @id
  nickname    String
  firstName   String?
  lastName    String?
  role        String?
  nationality String?
  imageUrl    String?  @db.Text
  updatedAt   DateTime @updatedAt
  memberships RosterMembership[]

  @@map("players")
}

model Roster {
  id           String   @id
  teamId       String
  tournamentId String?
  source       String
  fetchedAt    DateTime @default(now())
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  memberships  RosterMembership[]

  @@unique([teamId, tournamentId])
  @@index([teamId, fetchedAt])
  @@map("rosters")
}

model RosterMembership {
  rosterId   String
  playerId   String
  substitute Boolean?
  roster     Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  player     Player @relation(fields: [playerId], references: [id], onDelete: Restrict)

  @@id([rosterId, playerId])
  @@index([playerId])
  @@map("roster_memberships")
}

model Group {
  id             String   @id @default(cuid())
  name           String
  league         String
  tournament     String
  isPublic       Boolean  @default(false)
  invitationCode String   @unique
  ownerId        String
  createdAt      DateTime @default(now())
  owner          User     @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships    GroupMembership[]

  @@index([isPublic, name])
  @@index([ownerId])
  @@index([league, tournament])
  @@map("groups")
}

model GroupMembership {
  groupId  String
  userId   String
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_memberships")
}

model SyncRequest {
  id          String   @id
  requestedAt DateTime

  @@map("sync_requests")
}
