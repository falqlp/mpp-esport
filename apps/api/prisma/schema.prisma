generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String
  passwordHash String
  favoriteCompetitions String[] @default([])
  createdAt    DateTime @default(now())

  @@map("users")
}

model Prediction {
  id         String   @id @default(cuid())
  matchId    String
  playerName String
  winnerId   String
  scoreA     Int
  scoreB     Int
  createdAt  DateTime @default(now())
  points     Int      @default(0)

  @@unique([matchId, playerName])
  @@index([playerName])
  @@map("predictions")
}

model Match {
  id         String   @id
  league     String
  leagueLogoUrl String?
  tournament String
  startsAt   DateTime
  format     String
  status     String
  teams      Json
  winnerId   String?
  scoreA     Int?
  scoreB     Int?
  syncedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, startsAt])
  @@map("matches")
}
