{
  "name": "@mpp-esport/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "node ../../node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node ../../node_modules/prisma/build/index.js migrate deploy && node dist/main",
    "build": "node ../../node_modules/prisma/build/index.js generate && node ../../node_modules/@nestjs/cli/bin/nest.js build",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --coverage",
    "db:generate": "node ../../node_modules/prisma/build/index.js generate",
    "db:migrate": "node ../../node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "node ../../node_modules/prisma/build/index.js migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.0.0",
    "@prisma/client": "6.19.0",
    "dotenv": "^16.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/node": "^24.0.0",
    "prisma": "6.19.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
